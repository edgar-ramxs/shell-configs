function cudir() {
    local count="${1:-1}"
    
    if ! _lib_safe_numeric_input "$count" 1 20 "El n√ļmero de directorios debe estar entre 1 y 20"; then
        _lib_message -info "Uso: cudir [numero_directorios] (default: 1, max: 20)"
        return 1
    fi
    
    if ! _lib_check_command_exists seq; then
        _lib_message -error "seq no est√° disponible"
        return 1
    fi
    
    local path=""
    for i in $(seq 1 $count); do
        path="${path}../"
    done
    
    cd "$path" || {
        _lib_message -error "Error navegando $count directorios hacia arriba"
        return 1
    }
    
    _lib_message -info "Navegado $count directorios hacia arriba"
}


function fetch() {
    # Check if the library helper is available
    if ! declare -f _lib_find_first_available_command >/dev/null; then
        # Fallback to standard neofetch if available
        if command -v neofetch &>/dev/null; then neofetch "$@"; return 0; fi
        if command -v fastfetch &>/dev/null; then fastfetch "$@"; return 0; fi
        _lib_message -error "La librer√≠a compartida no se carg√≥ correctamente"
        return 1
    fi

    # 1. Intentar con comandos est√°ndar
    local cmd=$(_lib_find_first_available_command fastfetch neofetch)
    
    if [[ -n "$cmd" ]]; then
        "$cmd" "$@"
        return 0
    fi

    # 2. Intentar con fetchs caseros en src/bin/fetchinfo/
    local custom_fetch_dir="${DOTFILES_DIR}/src/bin/fetchinfo"
    if [[ -d "$custom_fetch_dir" ]]; then
        # Intentar en orden de preferencia
        for f in "fetching.sh" "zfetch.sh" "sysfetch.sh"; do
            if [[ -f "${custom_fetch_dir}/$f" ]]; then
                bash "${custom_fetch_dir}/$f" "$@"
                return 0
            fi
        done
    fi

    _lib_message -error "No se encontr√≥ ning√ļn comando de 'fetch'. Instala 'fastfetch' o 'neofetch'."
    return 1
}


